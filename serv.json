{
  "info": {
    "_postman_id": "8f6b9e11-5f89-4f4a-9d69-4f9f20a6a001",
    "name": "TemplatePERN - Services",
    "description": "Colección para testear endpoints de servicios con login previo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "serviceId",
      "value": "1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1) Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "if (data.token) {",
              "    pm.collectionVariables.set('token', data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2) Get all services",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/services",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "services"
          ]
        }
      }
    },
    {
      "name": "3) Get service by id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/services/{{serviceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "services",
            "{{serviceId}}"
          ]
        }
      }
    },
    {
      "name": "4) Create service",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/services",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "services"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"service_name\": \"Cambio de aceite\",\n  \"description\": \"Cambio completo con filtro\",\n  \"base_price\": 24990,\n  \"is_active\": true\n}"
        }
      }
    },
    {
      "name": "5) Update service",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/services/{{serviceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "services",
            "{{serviceId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"service_name\": \"Cambio de aceite premium\",\n  \"description\": \"Incluye revisión de niveles\",\n  \"base_price\": 29990,\n  \"is_active\": true\n}"
        }
      }
    },
    {
      "name": "6) Deactivate service",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/services/{{serviceId}}/deactivate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "services",
            "{{serviceId}}",
            "deactivate"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{}"
        }
      }
    }
  ]
}